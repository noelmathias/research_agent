# Copy to .env and fill in values before deploying

# -- Ollama -----------------------------------------------------------------
# Local dev: http://localhost:11434
# Docker:    http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# -- FastAPI ----------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# -- Embeddings -------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# -- ChromaDB ---------------------------------------------------------------
# Docker: use absolute path matching volume mount
CHROMA_PERSIST_DIR=/app/data/vectorstore
CHROMA_COLLECTION_NAME=research_docs

# -- Chunking ---------------------------------------------------------------
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# -- Uploads ----------------------------------------------------------------
UPLOAD_DIR=/app/data/uploads
MAX_UPLOAD_SIZE_MB=50

# -- Evaluation -------------------------------------------------------------
CONFIDENCE_THRESHOLD=0.5
MAX_RETRIES=2

# -- Reports ----------------------------------------------------------------
REPORTS_DIR=/app/data/reports

# -- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# -- Frontend ---------------------------------------------------------------
# Must point to backend service name in Docker network
BACKEND_URL=http://backend:8000
